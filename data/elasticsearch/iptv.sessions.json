// Kibana Dev Console — paste both blocks to create the sessions data stream.
// Replace "iptv" with your --es-index-prefix if different (e.g. iptv → myprefix → myprefix.sessions).

// Step 1: Create the index template
PUT _index_template/iptv.sessions
{
  "index_patterns": ["iptv.sessions"],
  "data_stream": {},
  "template": {
    "mappings": {
      "dynamic": "strict",
      "properties": {
        "@timestamp":        { "type": "date" },
        "event_kind":        { "type": "keyword" },
        "session_id":        { "type": "keyword" },
        "duration_seconds":  { "type": "long" },
        "bytes_transferred": { "type": "long" },
        "client_ip":         { "type": "keyword" },
        "user_agent":        { "type": "keyword" },
        "error_message":     { "type": "text" },
        "channel_id":        { "type": "keyword" },
        "channel_name":      { "type": "keyword" },
        "channel_group":     { "type": "keyword" },
        "channel_type":      { "type": "keyword" },
        "channel_stream_id": { "type": "keyword" },
        "user_name":         { "type": "keyword" },
        "proxy_mode":        { "type": "keyword" }
      }
    }
  },
  "priority": 200
}

// Step 2: Create the data stream
PUT _data_stream/iptv.sessions
